# Database
# Local development:
DATABASE_URL="file:./dev.db"
# Production (Supabase/Neon/Railway Postgres):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# JWT secret — generate with: openssl rand -base64 32
JWT_SECRET="your-strong-random-secret-here"

# ── WhatsApp Bot via UltraMsg (https://ultramsg.com) ──────────────────────────
# 1. Sign up at ultramsg.com and create an Instance
# 2. Connect your WhatsApp number by scanning the QR code in the dashboard
# 3. Set the Webhook URL in UltraMsg to: https://YOUR_DOMAIN/api/whatsapp/webhook
# 4. Copy your Instance ID and Token below
ULTRAMSG_INSTANCE="instance12345"
ULTRAMSG_TOKEN="your_ultramsg_token_here"

# Your deployed app URL (used to verify webhook signatures)
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# ── Online fee payments via Paymob (https://paymob.com) ───────────────────────
# All four are required to turn on the "Pay Now" button in the parent portal.
# Find them in the Paymob dashboard:
#   PAYMOB_SECRET_KEY      → Settings → Account Info / API Keys → "Secret key"
#   PAYMOB_PUBLIC_KEY      → same page → "Public key"
#   PAYMOB_INTEGRATION_IDS → Pay → Payment Integrations → ID(s) of the
#                            integration(s) to offer (comma-separated to offer
#                            more than one, e.g. card + wallet: "12345,12346")
#   PAYMOB_HMAC_SECRET     → that integration → "HMAC" (under its settings)
# Then set the integration's "Transaction processed callback" / webhook URL to:
#   https://YOUR_DOMAIN/api/payments/webhook
# Apple Pay specifically must be switched on by Paymob support on request —
# it isn't a self-serve toggle in the dashboard.
PAYMOB_SECRET_KEY="your_paymob_secret_key_here"
PAYMOB_PUBLIC_KEY="your_paymob_public_key_here"
PAYMOB_INTEGRATION_IDS="12345"
PAYMOB_HMAC_SECRET="your_paymob_hmac_secret_here"
