# Database
# Local development:
DATABASE_URL="file:./dev.db"
# Production (Supabase/Neon/Railway Postgres):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# JWT secret — generate with: openssl rand -base64 32
JWT_SECRET="your-strong-random-secret-here"

# ── WhatsApp Bot via UltraMsg (https://ultramsg.com) ──────────────────────────
# 1. Sign up at ultramsg.com and create an Instance
# 2. Connect your WhatsApp number by scanning the QR code in the dashboard
# 3. Set the Webhook URL in UltraMsg to: https://YOUR_DOMAIN/api/whatsapp/webhook
# 4. Copy your Instance ID and Token below
ULTRAMSG_INSTANCE="instance12345"
ULTRAMSG_TOKEN="your_ultramsg_token_here"

# Your deployed app URL (used to verify webhook signatures)
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
